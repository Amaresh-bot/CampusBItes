# ==============================================================================
# ENVIRONMENT VARIABLES - SECURITY GUIDES & LABELS
# ==============================================================================
#
# Rule 1: CLIENT SAFE VARIABLES - Must be prefixed with "VITE_" to be exposed 
#         to the browser client. Never place secrets in these variables.
#
# Rule 2: SERVER ONLY SECRETS - Never prefix with "VITE_". They remain purely
#         in the Node.js context and are hidden from browser inspect tools.
#
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. SAFE FOR CLIENT (Exposed to Browser with "VITE_" prefix)
# ------------------------------------------------------------------------------

# Safe Public Supabase Credentials
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key..."

# App Location (Injected automatically at runtime by AI Studio)
VITE_APP_URL="https://your-applet-url.run.app"


# ------------------------------------------------------------------------------
# 2. SERVER ONLY SECRETS (Strictly Hidden from Browser - NO "VITE_" PREFIX)
# ------------------------------------------------------------------------------

# CRITICAL SECURITY TRUTH: SUPABASE_SERVICE_ROLE_KEY bypasses Row Level Security (RLS)
# completely. Keep this STRICTLY hidden in the backend.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key..."
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key..."

# Gemini AI API Key (Injected automatically at runtime by AI Studio)
GEMINI_API_KEY="AIzaSyYourGeminiKey..."

# Razorpay Secret Code
RAZORPAY_KEY_ID="rzp_test_yourKey..."
RAZORPAY_KEY_SECRET="yourRazorpaySecretCode..."
